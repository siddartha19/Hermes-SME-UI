# Alera bridge config. Copy to server/.env and fill in.
# Loaded automatically by `npm run hermes` and `npm run eval`.

# ── LLM (the crew's brain) ─────────────────────────────────────────────────────
# Already picked up from ~/.hermes/.env if not set here. Override the model to a
# cheaper/faster one to lower cost-per-task, and set matching prices for accurate
# cost accounting in the trace.
# OPENAI_API_KEY=sk-...
# ALERA_MODEL=gpt-5.4
# ALERA_PRICE_IN=1.25      # USD per 1M input tokens (for the trace cost math)
# ALERA_PRICE_OUT=10       # USD per 1M output tokens

# ── Telegram (primary REAL surface: a judge texts the bot, gets a real reply) ───
# 1) Message @BotFather → /newbot → copy the token below
# 2) restart `npm run hermes` → the poller goes live automatically
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ── Email (outbound) ───────────────────────────────────────────────────────────
# Preferred: Resend (HTTPS API, works on any domain, no SMTP/app-password dance).
#   RESEND_API_KEY=re_...
#   RESEND_FROM=Alera <onboarding@resend.dev>   # or a verified address on your domain
# Fallback: Gmail SMTP (needs a Google App Password — blocked on many Workspace domains).
#   GMAIL_USER=hello@yourshop.com
#   GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# ── ElevenLabs (voice power-up, +25) ───────────────────────────────────────────
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # optional (default "Rachel")
# ELEVENLABS_MODEL=eleven_turbo_v2_5         # optional

# ── Shopify (real order + stock lookup) ────────────────────────────────────────
# From a Shopify custom app (Admin API) with read_orders + read_products scopes.
# SHOPIFY_STORE=your-store.myshopify.com
# SHOPIFY_ADMIN_TOKEN=shpat_...

# ── Eval gate ──────────────────────────────────────────────────────────────────
# EVAL_MIN=0.8             # pass-rate below this blocks the release

# ── Bridge auth (optional shared secret) ───────────────────────────────────────
# ALERA_TOKEN=some-shared-secret            # also set VITE_HERMES_TOKEN in .env.local
